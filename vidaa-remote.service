[Unit]
Description=Vidaa TV Remote Control
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=<USERNAME>
WorkingDirectory=/opt/vidaa-remote
ExecStart=/opt/vidaa-remote/bin/python app.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
